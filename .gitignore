# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual envs
.venv/
venv/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Test artifacts
.coverage
htmlcov/

# Local design notes (not for public release until reviewed)
DESIGN_NOTES.md

# Privacy audit artifacts (committed only after manual review)
.privacy-audit-cache/

# These should never appear in this repo (data lives in ~/.agent/, not here)
# Listed as defense-in-depth.
*.jsonl
!templates/lessons.jsonl.example
!examples/**/*.jsonl
candidates/
semantic/lessons.jsonl
episodic/AGENT_LEARNINGS.jsonl

# Live brain — never commit user data into the framework repo.
.agent/

# Personal session artifacts — these belong in your brain, not the framework:
#   SECURITY_REVIEW.md      — security review of YOUR brain (employer/PII content)
#   RESUME.md               — overnight session notes
#   tmp/                    — scratch dir, persona reports, throwaway scripts
SECURITY_REVIEW.md
RESUME.md
tmp/

# Demo artifacts: the synthetic brain + isolated config/cache that
# demo/make_demo_brain.py and demo/demo.tape generate. Regenerable;
# only demo/demo.tape, demo/make_demo_brain.py and demo/demo.gif belong in git.
demo/brain/
demo/.cache/
demo/.config/
